# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Cloud Database configuration (For Full-Stack Cloud Deployments on Render/Railway/etc)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=

# Frontend API configuration (For static hosts like Netlify/Vercel pointing to an external backend)
VITE_API_URL=

# Public website URL — used in membership QR codes (always opens the live site, not localhost)
VITE_PUBLIC_SITE_URL=https://almasqi-sac.org.sa

# Server-side public URL (same as above, for saving member verify links in the database)
PUBLIC_SITE_URL=https://almasqi-sac.org.sa
